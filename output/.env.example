# AI Sales Agent — Template de variáveis de ambiente
# NÃO preencha este arquivo com valores reais.
# Use o Infisical: infisical run -- <comando>
# Adicione as variáveis no painel: https://app.infisical.com

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Evolution API (WhatsApp) ───────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_URL=

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=

# ── Observabilidade ────────────────────────────────────────
VICTORIA_METRICS_URL=
VICTORIA_LOGS_URL=
OTEL_SERVICE_NAME=ai-sales-agent
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Loja Integrada (por tenant — substituir {TENANT_ID}) ───
LOJA_INTEGRADA_API_KEY_{TENANT_ID}=
LOJA_INTEGRADA_STORE_ID_{TENANT_ID}=

# ── Crawler B2B (por tenant) ───────────────────────────────
CRAWLER_USER_{TENANT_ID}=
CRAWLER_PASS_{TENANT_ID}=
CRAWLER_BASE_URL_{TENANT_ID}=

# ── Ambiente ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
